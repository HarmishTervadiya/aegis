generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletAddress String   @id
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  
  triggers      TriggerConfig[]
  executions    ExecutionRecord[]
  vault         UserVault?
}

model TriggerConfig {
  id                  String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  triggerPda          String   @id
  userWallet          String
  defenseActive       Boolean
  offenseActive       Boolean
  defenseThresholdBps Int
  offenseThresholdBps Int
  executionCount      Int
  lastExecuted        Int
  
  user User @relation(fields: [userWallet], references: [walletAddress])
}

model ExecutionRecord {
  id           String   @id @default(uuid())
  userWallet   String
  mode         String
  marginfiUtil Int
  kaminoUtil   Int
  txSignature  String
  firedAt      DateTime @default(now())
  yieldEarned  Int      @default(0)
  
  user User @relation(fields: [userWallet], references: [walletAddress])
}

model UserVault {
  id              String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vaultPda        String   @id
  userWallet      String   @unique
  currentProtocol String
  usdcDeposited   BigInt
  lifetimeYield   BigInt
  depositedAt     DateTime @default(now())
  apyAtEntry      Float    @default(0)
  
  user User @relation(fields: [userWallet], references: [walletAddress])
}
