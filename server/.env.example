# Solana RPC endpoint
# Use a Helius or QuickNode free-tier URL for mainnet reads
# Use http://127.0.0.1:8899 for local validator
RPC_URL=http://127.0.0.1:8899

# Your deployed Aegis program ID (from anchor deploy output)
PROGRAM_ID=YOUR_PROGRAM_ID_HERE

# Path to the crank wallet keypair JSON file
# This wallet pays transaction fees for execute_trigger calls
# Fund it with a small amount of SOL (0.1 SOL is enough for testing)
CRANK_KEYPAIR_PATH=./crank-keypair.json

# How often to poll protocol state in seconds
POLL_INTERVAL_SECONDS=15

# Port for the Express server
PORT=3001

# Admin secret for protected endpoints
ADMIN_SECRET=your_secret_here

# Secret used to sign JWTs for wallet authentication
JWT_SECRET=a_long_random_string_change_in_production
